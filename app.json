{
  "expo": {
    "name": "board-game2",
    "slug": "board-game2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logojp.png",
    "scheme": "board-game2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alexandrenf.boardgame2",
      "icon": "./assets/images/logojp.png"
    },
    "android": {
      "icon": "./assets/images/logojp.png",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logojp.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.alexandrenf.boardgame2"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86141721-d0da-4860-a330-bebe168265b8"
      }
    },
    "owner": "alexandrenf",
    "updates": {
      "url": "https://u.expo.dev/86141721-d0da-4860-a330-bebe168265b8"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
