    "@react-three/fiber": "^9.4.2",
    "@react-three/postprocessing": "^3.0.4",
    "@types/three": "0.160.0",
    "convex": "^1.34.0",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
