    "@types/react": "~19.1.17",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "playwright": "^1.58.2",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.3",
    "workbox-cli": "^7.4.0"
  },
