{
  "name": "expo-template-default",
  "license": "0BSD",
  "main": "expo-router/entry",
  "version": "54.0.35",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web && workbox generateSW workbox-config.js",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:web-smoke": "playwright test --config=playwright.config.ts",
    "bundle:check": "node ./scripts/check-bundle-size.js",
    "verify": "bunx expo-doctor && bunx expo install --check && bun run typecheck && bun run lint && bun run test",
    "draft": "bunx eas-cli@latest workflow:run create-draft.yml",
    "development-builds": "bunx eas-cli@latest workflow:run create-development-builds.yml",
    "deploy": "bunx eas-cli@latest workflow:run deploy-to-production.yml"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
